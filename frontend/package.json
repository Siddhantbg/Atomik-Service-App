{
  "name": "atomik-frontend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-expo.ps1",
    "qr": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/show-qr.ps1",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "config:check": "expo config --type public",
    "doctor": "npx expo-doctor",
    "eas:init": "eas init",
    "eas:configure": "eas build:configure",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "submit:android": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@expo-google-fonts/space-mono": "^0.2.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "@reduxjs/toolkit": "^2.2.5",
    "axios": "^1.7.2",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
