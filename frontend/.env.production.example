# Copy values into EAS Secrets (recommended) or eas.json production.env
# NEVER commit real production secrets to git.

# Required — production API (HTTPS)
EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api

# Required — Razorpay LIVE public key (checkout in app)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx

# Required for map venue picker
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_android_key

# DO NOT set in production builds:
# EXPO_PUBLIC_DEMO_PASSWORD=
