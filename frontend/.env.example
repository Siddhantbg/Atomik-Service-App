# API URL — use your PC LAN IP when testing on a physical phone (not localhost)
# MongoDB is configured in backend/.env (MONGODB_URI), not here.
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:5000/api

# Optional — Appwrite (future client SDK session exchange)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_appwrite_project_id
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_here
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here
# Offline demo login (__DEV__ only; must match backend DEMO_USER_PASSWORD)
EXPO_PUBLIC_DEMO_PASSWORD=your_demo_password_here
