# Paste these into Render → atomik-api → Environment (free web service).
# Copy values from your local backend/.env — never commit .env to git.

MONGODB_URI=mongodb+srv://...
JWT_SECRET=                    # Render can auto-generate on first deploy
CLIENT_URL=https://atomikaudio.com
APP_PUBLIC_URL=https://atomikaudio.com
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=ATOMIK
