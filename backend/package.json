{
  "name": "atomik-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/free-port.ps1 && nodemon --exec ts-node src/server.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/templates/html','dist/templates/html',{recursive:true})\"",
    "start": "node dist/server.js",
    "test": "jest",
    "seed": "ts-node src/scripts/seed.ts",
    "clear-demo-data": "ts-node src/scripts/clearDemoData.ts",
    "twilio:test": "ts-node src/scripts/testTwilio.ts",
    "check-secrets": "ts-node scripts/check-secrets.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "razorpay": "^2.9.2",
    "xss-clean": "^0.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
