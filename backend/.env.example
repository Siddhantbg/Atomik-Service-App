PORT=5000
# MongoDB Atlas — replace with your cluster URI (include database name, e.g. /atomik)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/atomik?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=change_me_to_a_long_random_string
# Required for npm run seed (local dev only — never use in production)
DEMO_USER_PASSWORD=your_demo_password_here
# Max JSON body size (default 512kb)
# JSON_BODY_LIMIT=512kb
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Optional: force demo payments in dev (no Razorpay checkout)
# RAZORPAY_FORCE_DEMO=true
# Allow demo payments from LAN/mobile dev (default: localhost only)
# ALLOW_DEMO_PAYMENTS=true
# Test keys: https://dashboard.razorpay.com/app/keys — set same KEY_ID in frontend EXPO_PUBLIC_RAZORPAY_KEY_ID
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio SMS OTP (default — see TWILIO_AUTH_SETUP.md)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Optional Appwrite OTP (only if you set APPWRITE_PROJECT_ID; leave empty for Twilio-only)
# APPWRITE_ENDPOINT=
# APPWRITE_PROJECT_ID=
# APPWRITE_API_KEY=

# Resend transactional email (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
# Sandbox: onboarding@resend.dev (only delivers to your Resend account email until domain is verified)
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=ATOMIK
# Links in emails (dashboard, track, reset password)
APP_PUBLIC_URL=https://atomik.app

# Legacy SendGrid (optional fallback for from-address lookup only)
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=ATOMIK
